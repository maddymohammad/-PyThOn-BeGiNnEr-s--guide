## 4. Strings — the most-used methods

```python
s.upper()  s.lower()  s.title()  s.capitalize()
s.strip()  s.lstrip()  s.rstrip()      # remove surrounding whitespace
s.replace(old, new)
s.split(",")                           # str -> list
",".join(list_of_strings)              # list -> str
s.find(sub)        # index or -1
s.index(sub)       # index or error
s.count(sub)
s.startswith(x)  s.endswith(x)
s.isdigit()  s.isalpha()  s.isalnum()  s.isspace()
s.zfill(5)  s.center(10)  s.ljust(10)  s.rjust(10)

# Slicing (works on strings AND lists):
s[start:stop:step]
s[::-1]            # reverse
s[2:]   s[:3]   s[-1]

# f-strings (use these for formatting):
name = "Sam"
f"Hello {name}, score is {score:.2f}"
```

---

## 5. Lists

```python
lst.append(x)          # add one to end
lst.extend([a, b])     # add many
lst.insert(i, x)
lst.pop()      lst.pop(i)
lst.remove(value)
lst.index(value)
lst.count(value)
lst.sort()     lst.sort(reverse=True)   # in place
lst.reverse()  # in place
lst.copy()
lst.clear()

sorted(lst)            # returns a NEW sorted list
reversed(lst)          # returns an iterator
min(lst)  max(lst)  sum(lst)

# List comprehension (very widely used):
[x*2 for x in lst]
[x for x in lst if x > 0]
[(x, y) for x in a for y in b]
```

---

## 6. Dictionaries

```python
d["key"]               # access (error if missing)
d.get("key")           # None if missing
d.get("key", default)
d["key"] = value       # set/update
d.keys()  d.values()  d.items()
d.pop("key")
d.update({"a": 1})
"key" in d             # membership checks KEYS
del d["key"]

# Iterate:
for k, v in d.items():
    print(k, v)

# Dict comprehension:
{k: v for k, v in pairs}
{x: x**2 for x in range(5)}
```

---

## 7. Sets

```python
s.add(x)   s.remove(x)   s.discard(x)   # discard = no error if missing
a | b      # union
a & b      # intersection
a - b      # difference
a ^ b      # symmetric difference
# Sets auto-remove duplicates; great for "have I seen this?" checks.
```

---

## 8. Control flow

```python
if cond:
    ...
elif other:
    ...
else:
    ...

# Ternary:
x = "yes" if cond else "no"

while cond:
    ...
    break        # exit loop
    continue     # skip to next iteration

for i in range(10):        # 0..9
for i in range(2, 10):     # 2..9
for i in range(0, 10, 2):  # 0,2,4,6,8
for item in lst:
for i, item in enumerate(lst):     # index + value
for a, b in zip(list1, list2):     # parallel iteration

for ...:
    ...
else:            # runs if loop finished WITHOUT break
    ...
```

